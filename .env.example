# Database
MAILDB_DATABASE_URL=postgresql://maildb@localhost:5432/maildb

# Test database (used by pytest)
# MAILDB_TEST_DATABASE_URL=postgresql://maildb_test@localhost:5432/maildb_test

# Ollama embedding service
MAILDB_OLLAMA_URL=http://localhost:11434
MAILDB_EMBEDDING_MODEL=nomic-embed-text
MAILDB_EMBEDDING_DIMENSIONS=768

# User identity (required for unreplied() and top_contacts())
# MAILDB_USER_EMAIL=you@example.com

# Ingest directories
# MAILDB_ATTACHMENT_DIR=~/maildb/attachments
# MAILDB_INGEST_TMP_DIR=/tmp/maildb-ingest-tmp-dir

# Ingest tuning
# MAILDB_INGEST_CHUNK_SIZE_MB=50
# MAILDB_INGEST_WORKERS=-1          # -1 = CPU count - 1
# MAILDB_EMBED_WORKERS=4
# MAILDB_EMBED_BATCH_SIZE=50
